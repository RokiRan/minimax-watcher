# =============================================================================
# minimax-watcher 必填项（脚本里有默认值，下面这些是真正需要您手填的）
# =============================================================================

# MiniMax / minimax token plan 查询 API key
MINIMAX_API_KEY=

# NewAPI 服务地址，例如 https://newapi.example.com
NEWAPI_BASE_URL=
# NewAPI 管理员 token（在 NewAPI 系统设置里生成）
NEWAPI_ADMIN_TOKEN=
# NewAPI 管理员的数字用户 ID（new-api fork 强制要求 New-Api-User header）
NEWAPI_ADMIN_USER_ID=
# 渠道 tag：先在 NewAPI 后台给目标渠道打 tag（如 "minimax"），脚本用 tag 批量控制
# 参考：https://docs.newapi.pro/zh/docs/api/management/channel-management/channel-tag-disabled-post
NEWAPI_CHANNEL_TAG=


# =============================================================================
# 可选：默认值已经针对 minimax coding_plan/remains 接口调好，按需覆盖
# =============================================================================

# --- MiniMax 接口与字段（默认值已验证过 minimax coding_plan/remains）----
# MINIMAX_QUERY_URL=https://www.minimaxi.com/v1/api/openplatform/coding_plan/remains
# MINIMAX_MODE=max_usage
# MINIMAX_ARRAY_PATH=model_remains
# MINIMAX_USED_METRIC=remaining_percent    # count | remaining_percent
#                                            # count              = *_usage_count / *_total_count
#                                            # remaining_percent  = 100 - *_remaining_percent  (默认)
# MINIMAX_REMAIN_PERCENT_FIELD=current_interval_remaining_percent
# MINIMAX_USED_FIELD=current_interval_usage_count    # 仅当 USED_METRIC=count 时生效
# MINIMAX_TOTAL_FIELD=current_interval_total_count  # 仅当 USED_METRIC=count 时生效
# MINIMAX_RESET_FIELD=end_time
# MINIMAX_HTTP_METHOD=GET
# MINIMAX_AUTH_HEADER=Bearer
# MINIMAX_MODEL_FILTER=general            # 默认只看 general；留空 = 监控所有模型
# MINIMAX_EXTRA_HEADERS=               # JSON 字符串，追加到请求头
# MINIMAX_REQUEST_BODY=                # POST body 的 JSON 字符串
# MINIMAX_USED=                        # 显式覆盖 used（置后字段路径失效）
# MINIMAX_TOTAL=                       # 显式覆盖 total
# MINIMAX_REMAIN=                      # 显式覆盖 remain


# --- 阈值与调度 ---
# USAGE_THRESHOLD=98                # 触发停用的使用率百分比（剩余 < 2%）
# POLL_INTERVAL_MS=30000           # 轮询间隔毫秒（默认 30 秒）
# LOG_LEVEL=info                    # debug / info / warn / error
# RUN_ONCE=false                    # true = 只跑一轮就退出（调试 / cron 用）

# 注意：脚本不保存任何本地状态。每次决策仅基于当前一次查询结果。
#   用量 ≥ USAGE_THRESHOLD → POST /api/channel/tag/disabled
#   用量 < USAGE_THRESHOLD → POST /api/channel/tag/enabled
# NewAPI tag 接口对重复调用幂等（已实测），无需去重缓存。